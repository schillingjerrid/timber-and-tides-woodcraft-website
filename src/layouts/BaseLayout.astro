---
import "../styles/theme.css";

const {
  title = "Timber and Tides Woodcraft",
  description = "Handcrafted woodworking projects and commissions.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <meta name="theme-color" content="#0b0f0e" />

    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
  </head>

  <body class="min-h-screen bg-bg text-fg">
    <!-- Sticky header with scroll-hide behaviour -->
    <header
      id="site-header"
      class="sticky top-0 z-50 border-b border-border bg-bg/95 backdrop-blur-sm transition-transform duration-300 ease-in-out"
    >
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <!-- Logo -->
        <a href="/" class="inline-flex shrink-0 items-center" aria-label="Timber and Tides Woodcraft home">
          <img
            src="/images/logos/tatw-logo_filled.svg"
            alt="Timber and Tides Woodcraft"
            class="h-10 w-auto"
          />
        </a>

        <!-- Desktop nav -->
        <nav class="hidden items-center gap-6 text-sm text-muted md:flex">
          <a class="transition hover:text-fg" href="/projects/">Projects</a>
          <a class="transition hover:text-fg" href="/plans/">Plans</a>
          <a class="transition hover:text-fg" href="/testimonials/">Feedback</a>
          <a class="transition hover:text-fg" href="/about/">About</a>
          <a class="transition hover:text-fg" href="/contact/">Contact</a>
        </nav>

        <!-- Hamburger toggle (mobile/tablet only) -->
        <button
          id="nav-toggle"
          class="inline-flex items-center justify-center rounded-md p-2 text-muted transition hover:text-fg md:hidden"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-nav"
          aria-label="Toggle navigation"
        >
          <!-- Hamburger icon -->
          <svg
            id="icon-menu"
            class="h-6 w-6"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <!-- Close (X) icon -->
          <svg
            id="icon-close"
            class="hidden h-6 w-6"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Mobile/tablet dropdown nav -->
      <div
        id="mobile-nav"
        class="overflow-hidden transition-[max-height,opacity] duration-300 ease-in-out md:hidden"
        style="max-height: 0; opacity: 0;"
      >
        <nav class="flex flex-col gap-1 border-t border-border px-4 py-3">
          <a
            class="rounded-md px-3 py-2 text-sm text-muted transition hover:bg-surface hover:text-fg"
            href="/projects/"
            data-mobile-nav-link
          >Projects</a>
          <a
            class="rounded-md px-3 py-2 text-sm text-muted transition hover:bg-surface hover:text-fg"
            href="/plans/"
            data-mobile-nav-link
          >Plans</a>
          <a
            class="rounded-md px-3 py-2 text-sm text-muted transition hover:bg-surface hover:text-fg"
            href="/testimonials/"
            data-mobile-nav-link
          >Feedback</a>
          <a
            class="rounded-md px-3 py-2 text-sm text-muted transition hover:bg-surface hover:text-fg"
            href="/about/"
            data-mobile-nav-link
          >About</a>
          <a
            class="rounded-md px-3 py-2 text-sm text-muted transition hover:bg-surface hover:text-fg"
            href="/contact/"
            data-mobile-nav-link
          >Contact</a>
        </nav>
      </div>
    </header>

    <main class="pb-16">
      <slot />
    </main>

    <!-- ── Back to top button ──────────────────────────────────────────────── -->
    <button
      id="back-to-top"
      type="button"
      aria-label="Back to top"
      class="fixed bottom-6 right-6 z-40 flex h-10 w-10 items-center justify-center rounded-full border border-border bg-surface text-muted shadow-lg transition-all duration-300 ease-in-out hover:border-zinc-600 hover:bg-surface-2 hover:text-fg opacity-0 translate-y-4 pointer-events-none"
    >
      <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <footer class="border-t border-border py-8 text-sm text-zinc-400">
      <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 sm:flex-row sm:items-center sm:justify-between">
        <p>&copy; {new Date().getFullYear()} Timber and Tides Woodcraft</p>
        <p class="text-zinc-400">Made in Colorado • Commissions welcome</p>
      </div>
    </footer>

    <script>
      // ── Mobile nav toggle ──────────────────────────────────────────────────

      const toggle = document.getElementById("nav-toggle");
      const mobileNav = document.getElementById("mobile-nav");
      const iconMenu = document.getElementById("icon-menu");
      const iconClose = document.getElementById("icon-close");

      let navOpen = false;

      function setNavOpen(next: boolean) {
        navOpen = next;
        toggle?.setAttribute("aria-expanded", String(navOpen));

        if (!mobileNav) return;

        if (navOpen) {
          // Expand: set max-height to scrollHeight so CSS transition works
          mobileNav.style.maxHeight = mobileNav.scrollHeight + "px";
          mobileNav.style.opacity = "1";
        } else {
          mobileNav.style.maxHeight = "0";
          mobileNav.style.opacity = "0";
        }

        iconMenu?.classList.toggle("hidden", navOpen);
        iconClose?.classList.toggle("hidden", !navOpen);
      }

      // Toggle on button click
      toggle?.addEventListener("click", (e) => {
        e.stopPropagation();
        setNavOpen(!navOpen);
      });

      // Close when a nav link is clicked
      document.querySelectorAll("[data-mobile-nav-link]").forEach((link) => {
        link.addEventListener("click", () => setNavOpen(false));
      });

      // Close when clicking outside the header
      document.addEventListener("click", (e) => {
        if (!navOpen) return;
        const header = document.getElementById("site-header");
        if (header && e.target instanceof Node && !header.contains(e.target)) {
          setNavOpen(false);
        }
      });

      // Close on Escape
      window.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && navOpen) setNavOpen(false);
      });

      // ── Scroll-hide / scroll-reveal + back-to-top ─────────────────────────

      const header = document.getElementById("site-header");
      const backToTop = document.getElementById("back-to-top");
      let lastScrollY = window.scrollY;
      let ticking = false;

      function setBackToTop(visible: boolean) {
        if (!backToTop) return;
        if (visible) {
          backToTop.classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
          backToTop.classList.add("opacity-100", "translate-y-0", "pointer-events-auto");
        } else {
          backToTop.classList.add("opacity-0", "translate-y-4", "pointer-events-none");
          backToTop.classList.remove("opacity-100", "translate-y-0", "pointer-events-auto");
        }
      }

      backToTop?.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });

      window.addEventListener(
        "scroll",
        () => {
          if (ticking) return;
          ticking = true;

          window.requestAnimationFrame(() => {
            const currentScrollY = window.scrollY;
            const delta = currentScrollY - lastScrollY;

            if (currentScrollY <= 0) {
              // Always show header at very top
              header?.classList.remove("-translate-y-full");
            } else if (delta > 8) {
              // Scrolling down — hide header
              header?.classList.add("-translate-y-full");
              // Also close mobile nav if open
              if (navOpen) setNavOpen(false);
            } else if (delta < -8) {
              // Scrolling up — reveal header
              header?.classList.remove("-translate-y-full");
            }

            // Back-to-top: show after scrolling down 200px, hide at top
            setBackToTop(currentScrollY > 200);

            lastScrollY = currentScrollY;
            ticking = false;
          });
        },
        { passive: true }
      );
    </script>
  </body>
</html>
