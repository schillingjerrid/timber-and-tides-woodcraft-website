---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type Props = {
  images?: ImageMetadata[];
  altPrefix?: string;
};

const props = Astro.props as Props;
const images: ImageMetadata[] = props.images ?? [];
const altPrefix: string = props.altPrefix ?? "Project photo";

// Unique ID per gallery instance so multiple galleries on a page don't conflict
const id = `gallery-${Math.random().toString(36).slice(2, 8)}`;

// Pass full-resolution image src list to the client-side lightbox.
const fullSrcs = images.map((img) => img.src);
---

{images.length > 0 && (
  <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2" id={id}>
    {images.map((img: ImageMetadata, i: number) => (
      <button
        type="button"
        class="gallery-thumb overflow-hidden rounded-xl border border-border bg-surface cursor-zoom-in focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
        data-index={i}
        aria-label={`View ${altPrefix} — detail ${i + 1} fullscreen`}
      >
        <Image
          src={img}
          alt={`${altPrefix} — detail photo ${i + 1}`}
          width={800}
          height={800}
          loading="lazy"
          class="h-full w-full object-cover pointer-events-none"
        />
      </button>
    ))}
  </div>

  <!-- Lightbox overlay -->
  <div
    id={`${id}-lightbox`}
    class="lightbox fixed inset-0 z-50 hidden items-center justify-center"
    role="dialog"
    aria-modal="true"
    aria-label="Image viewer"
  >
    <!-- Backdrop -->
    <div class="lightbox-backdrop absolute inset-0 bg-black/80 backdrop-blur-sm"></div>

    <!-- Close button -->
    <button
      type="button"
      class="lightbox-close absolute top-4 right-4 z-10 rounded-full bg-black/60 p-2 text-white/80 hover:text-white hover:bg-black/80 transition"
      aria-label="Close viewer"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Prev button -->
    <button
      type="button"
      class="lightbox-prev absolute left-3 top-1/2 -translate-y-1/2 z-10 rounded-full bg-black/60 p-3 text-white/80 hover:text-white hover:bg-black/80 transition"
      aria-label="Previous image"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <!-- Image -->
    <div class="relative z-10 flex max-h-[90vh] max-w-[90vw] items-center justify-center">
      <img
        class="lightbox-img max-h-[90vh] max-w-[90vw] rounded-xl object-contain shadow-2xl"
        src=""
        alt=""
      />
    </div>

    <!-- Next button -->
    <button
      type="button"
      class="lightbox-next absolute right-3 top-1/2 -translate-y-1/2 z-10 rounded-full bg-black/60 p-3 text-white/80 hover:text-white hover:bg-black/80 transition"
      aria-label="Next image"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- Counter -->
    <p class="lightbox-counter absolute bottom-4 left-1/2 -translate-x-1/2 z-10 text-sm text-white/60 tabular-nums"></p>
  </div>
)}

<script is:inline define:vars={{ id, fullSrcs, altPrefix }}>
  const gallery = document.getElementById(id);
  if (!gallery) return;

  const lightbox = document.getElementById(`${id}-lightbox`);
  const lbImg = lightbox.querySelector(".lightbox-img");
  const lbCounter = lightbox.querySelector(".lightbox-counter");
  let current = 0;

  function show(index) {
    current = (index + fullSrcs.length) % fullSrcs.length;
    lbImg.src = fullSrcs[current];
    lbImg.alt = `${altPrefix} — detail photo ${current + 1}`;
    lbCounter.textContent = `${current + 1} / ${fullSrcs.length}`;
  }

  function open(index) {
    show(index);
    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
    document.body.style.overflow = "hidden";
    lightbox.querySelector(".lightbox-close").focus();
  }

  function close() {
    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
    document.body.style.overflow = "";
  }

  // Thumbnail clicks
  gallery.querySelectorAll(".gallery-thumb").forEach((btn) => {
    btn.addEventListener("click", () => open(Number(btn.dataset.index)));
  });

  // Controls
  lightbox.querySelector(".lightbox-close").addEventListener("click", close);
  lightbox.querySelector(".lightbox-prev").addEventListener("click", () => show(current - 1));
  lightbox.querySelector(".lightbox-next").addEventListener("click", () => show(current + 1));

  // Backdrop click closes
  lightbox.querySelector(".lightbox-backdrop").addEventListener("click", close);

  // Keyboard navigation
  lightbox.addEventListener("keydown", (e) => {
    if (e.key === "Escape") close();
    if (e.key === "ArrowLeft") show(current - 1);
    if (e.key === "ArrowRight") show(current + 1);
  });
</script>
