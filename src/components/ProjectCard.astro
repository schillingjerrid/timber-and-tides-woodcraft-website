---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import TagPill from "./TagPill.astro";

type Props = {
  href: string;
  title: string;
  excerpt?: string;
  coverImage: ImageMetadata;
  tags?: string[];
  hasPlans?: boolean;
  date?: Date;
};

const props = Astro.props as Props;
const href: string = props.href;
const title: string = props.title;
const excerpt: string | undefined = props.excerpt;
const coverImage: ImageMetadata = props.coverImage;
const tags: string[] = props.tags ?? [];
const hasPlans: boolean = props.hasPlans ?? false;
const date: Date | undefined = props.date;

const dateLabel = date
  ? new Intl.DateTimeFormat("en-US", {
      month: "short",
      year: "numeric",
      timeZone: "UTC",
    }).format(date)
  : undefined;
const dateISO = date ? date.toISOString().slice(0, 10) : undefined;
---

<a
  href={href}
  class="group overflow-hidden rounded-2xl border border-border bg-surface hover:bg-surface-2 transition"
>
  <div class="relative aspect-16/10 overflow-hidden bg-surface">
    <Image
      src={coverImage}
      alt={`${title} — custom woodworking project`}
      width={640}
      height={400}
      loading="lazy"
      class="h-full w-full object-cover group-hover:scale-[1.02] transition"
    />
    {hasPlans && (
      <span class="absolute top-2.5 right-2.5 inline-flex items-center gap-1 rounded-full bg-black/60 px-2.5 py-1 text-xs font-semibold text-secondary ring-1 ring-inset ring-secondary/70 backdrop-blur-sm">
        <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Plans Available
      </span>
    )}
  </div>

  <div class="p-4">
    {dateLabel && (
      <time
        datetime={dateISO}
        class="block text-[0.6875rem] font-semibold uppercase tracking-[0.18em] text-secondary"
      >
        {dateLabel}
      </time>
    )}

    <h3 class={`${dateLabel ? "mt-1.5" : ""} text-base font-semibold`}>{title}</h3>

    {excerpt && <p class="mt-1 text-sm text-muted">{excerpt}</p>}

    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {tags.slice(0, 4).map((t: string) => (
          <TagPill tag={t} />
        ))}
      </div>
    )}
  </div>
</a>
