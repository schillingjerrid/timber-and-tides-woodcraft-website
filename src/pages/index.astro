---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const plans = await getCollection("plans");

const featured = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);

const recent = [...projects]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const testimonials = await getCollection("testimonials");

// Repeat testimonials enough so each half of the marquee track fills any viewport.
// Each card is w-72 (288px) + mr-6 right margin (24px) = 312px stride.
// Target ≥12 cards per half so the loop has ample fill at any screen width.
const MIN_CARDS_PER_SET = 12;
const repeatCount = Math.max(1, Math.ceil(MIN_CARDS_PER_SET / Math.max(1, testimonials.length)));
const repeatedSet = Array.from({ length: repeatCount }, () => testimonials).flat();
// Duration keeps scroll speed ≈ 80 px/s regardless of repeat count
const CARD_STRIDE_PX = 312;
const marqueeDuration = Math.round((repeatedSet.length * CARD_STRIDE_PX) / 80);
---

<BaseLayout
  title="Timber and Tides Woodcraft"
  description="Handcrafted woodworking projects, client feedback, and commission requests."
>

  <!-- ── 1. Hero ── wood bg (background-3) ───────────────────────────────── -->
  <section class="relative overflow-hidden bg-surface py-10">
    <div
      class="absolute inset-0 bg-cover bg-center pointer-events-none"
      style="background-image: url('/images/backgrounds/background-3_large.jpg');"
    ></div>
    <!-- Overlay increased to /65 for legible text over any wood brightness -->
    <div class="absolute inset-0 bg-zinc-900/65 pointer-events-none"></div>

    <div class="relative mx-auto max-w-6xl px-4">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">
        Handcrafted woodworking, built to last.
      </h1>
      <p class="mt-3 max-w-2xl text-fg">
        I build custom pieces and thoughtful gifts ~ tables, shelves, cabinets, and more.
        Browse recent work, read client feedback, and reach out to request a commission.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/projects/"
          class="group inline-flex items-center justify-center rounded-xl border border-secondary/60 bg-surface px-4 py-2 text-sm font-semibold text-fg
                transition will-change-transform
                hover:bg-surface-2 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-black/30
                active:translate-y-0
                focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          View Projects
          <span class="ml-2 opacity-70 transition group-hover:opacity-100 group-hover:translate-x-0.5">→</span>
        </a>

        <a
          href="/contact/"
          class="group inline-flex items-center justify-center rounded-xl bg-primary px-4 py-2 text-sm font-semibold text-bg
                transition will-change-transform
                hover:-translate-y-0.5 hover:shadow-lg hover:shadow-black/30 hover:brightness-110
                active:translate-y-0
                focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          Request a Commission
          <span class="ml-2 opacity-80 transition group-hover:rotate-6 group-hover:scale-110">✦</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── 2. Featured Projects ── plain dark bg ───────────────────────────── -->
  <section class="mt-8">
    <div class="mx-auto max-w-6xl px-4">
      <div class="flex items-end justify-between gap-4">
        <h2 class="text-xl font-semibold">Featured Projects</h2>
        <a class="text-primary hover:text-fg transition" href="/projects/">See all →</a>
      </div>

      {featured.length === 0 ? (
        <p class="mt-4 text-muted">
          Add a project in <code class="text-fg">src/content/projects</code> to get started.
        </p>
      ) : (
        <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {featured.map((p) => (
            <ProjectCard
              href={`/projects/${p.slug}/`}
              title={p.data.title}
              excerpt={p.data.excerpt}
              coverImage={p.data.coverImage}
              tags={p.data.tags}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ── 3. Testimonials Marquee ── wood bg (background-2) ──────────────── -->
  {testimonials.length > 0 && (
    <section
      class="relative mt-10 overflow-hidden py-14"
      aria-label="Customer testimonials"
    >
      <div
        class="absolute inset-0 bg-cover bg-center pointer-events-none"
        style="background-image: url('/images/backgrounds/background-2_large.jpg');"
      ></div>
      <div class="absolute inset-0 bg-zinc-900/65 pointer-events-none"></div>

      <div class="relative">
        <h2 class="mb-8 text-center text-xl font-semibold">What Clients Say</h2>

        <!--
          Marquee: each card gets mr-6 (24px) instead of gap on the flex container.
          This means every card — including the last in each half — adds the same
          trailing space, so translateX(-50%) lands exactly at the start of the
          second half and the loop is seamless.
        -->
        <div class="group overflow-hidden" role="marquee">
          <div
            class="marquee-track flex"
            style={`animation-duration: ${marqueeDuration}s`}
          >
            {/* First half — visible to screen readers */}
            {repeatedSet.map((t) => (
              <article class="mr-6 w-72 shrink-0 rounded-2xl border border-border bg-surface/80 backdrop-blur-sm px-6 py-5">
                <p class="text-sm leading-relaxed text-fg">"{t.body.trim()}"</p>
                <footer class="mt-4">
                  <p class="text-sm font-semibold text-primary">{t.data.name}</p>
                  {t.data.roleOrContext && (
                    <p class="text-xs text-muted">{t.data.roleOrContext}</p>
                  )}
                </footer>
              </article>
            ))}
            {/* Second half — aria-hidden duplicate for seamless loop */}
            {repeatedSet.map((t) => (
              <article
                class="mr-6 w-72 shrink-0 rounded-2xl border border-border bg-surface/80 backdrop-blur-sm px-6 py-5"
                aria-hidden="true"
              >
                <p class="text-sm leading-relaxed text-fg">"{t.body.trim()}"</p>
                <footer class="mt-4">
                  <p class="text-sm font-semibold text-primary">{t.data.name}</p>
                  {t.data.roleOrContext && (
                    <p class="text-xs text-muted">{t.data.roleOrContext}</p>
                  )}
                </footer>
              </article>
            ))}
          </div>
        </div>

        <div class="mt-8 text-center">
          <a
            href="/testimonials/"
            class="text-sm text-primary hover:text-fg transition"
          >Read all feedback →</a>
        </div>
      </div>
    </section>
  )}

  <!-- ── 4. Recent Work ── plain dark bg ─────────────────────────────────── -->
  {recent.length > 0 && (
    <section class="mt-10">
      <div class="mx-auto max-w-6xl px-4">
        <div class="flex items-end justify-between gap-4">
          <h2 class="text-xl font-semibold">Recent Work</h2>
          <a class="text-primary hover:text-fg transition" href="/projects/">See all →</a>
        </div>

        <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {recent.map((p) => (
            <ProjectCard
              href={`/projects/${p.slug}/`}
              title={p.data.title}
              excerpt={p.data.excerpt}
              coverImage={p.data.coverImage}
              tags={p.data.tags}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── 5. About Teaser ── wood bg (background-1) ───────────────────────── -->
  <section class="relative mt-10 overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center pointer-events-none"
      style="background-image: url('/images/backgrounds/background-1_large.jpg');"
    ></div>
    <div class="absolute inset-0 bg-zinc-900/65 pointer-events-none"></div>

    <div class="relative mx-auto max-w-6xl px-4 py-12">
      <p class="text-xs font-semibold uppercase tracking-widest text-secondary">About the Shop</p>
      <h2 class="mt-2 text-2xl font-bold tracking-tight">Small shop. Serious craft.</h2>
      <p class="mt-4 max-w-2xl text-fg">
        Timber and Tides Woodcraft is a one-person shop based in Colorado, building
        custom furniture, kitchen pieces, and gifts from the ground up. Every project
        starts with carefully selected lumber and ends with a piece meant to outlast trends.
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-5">
        <a
          href="/about/"
          class="group inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-fg transition"
        >
          Learn more about the shop
          <span class="transition group-hover:translate-x-0.5">→</span>
        </a>

        <a
          href="https://www.instagram.com/timberandtideswoodcraft/"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 text-sm font-semibold text-zinc-400 hover:text-fg transition"
        >
          <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          Follow on Instagram
        </a>
      </div>
    </div>
  </section>

  <!-- ── 6. Plans ── card with glow ─────────────────────────────────────── -->
  <section class="mt-10">
    <div class="mx-auto max-w-6xl px-4">
      <div class="plans-card rounded-2xl border border-border bg-surface px-8 py-8">
        <h2 class="text-lg font-semibold">Free Woodworking Plans</h2>
        <p class="mt-2 max-w-xl text-muted">
          {plans.length === 1 ? "1 plan available now" : `${plans.length} plans available`} — more coming soon.
          Download cut lists and dimensioned drawings for builds from the shop.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a
            href="/plans/"
            class="group inline-flex items-center justify-center rounded-xl bg-primary px-4 py-2 text-sm font-semibold text-bg
                  transition will-change-transform
                  hover:-translate-y-0.5 hover:shadow-lg hover:shadow-black/30 hover:brightness-110
                  active:translate-y-0
                  focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
          >
            Browse Plans
            <span class="ml-2 opacity-80 transition group-hover:translate-x-0.5">→</span>
          </a>
          <a
            href="/contact/"
            class="inline-flex items-center justify-center rounded-xl border border-border bg-surface-2 px-4 py-2 text-sm font-semibold text-fg hover:bg-surface transition"
          >
            Suggest a plan idea
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .marquee-track {
    /* duration is set via inline style so it scales with card count */
    animation: marquee-scroll linear infinite;
  }

  /* Pause on hover */
  .group:hover .marquee-track {
    animation-play-state: paused;
  }

  /* Plans card — very soft breathing glow */
  @keyframes glow-breathe {
    0%, 100% { box-shadow: 0 0 18px -10px rgba(139,162,194,0.10); }
    50%       { box-shadow: 0 0 28px -6px rgba(139,162,194,0.18); }
  }

  .plans-card {
    animation: glow-breathe 6s ease-in-out infinite;
  }

  /* Reduced-motion: static grid, hide duplicate set */
  @media (prefers-reduced-motion: reduce) {
    .plans-card { animation: none; box-shadow: 0 0 18px -10px rgba(139,162,194,0.10); }

    .marquee-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem;
    }

    .marquee-track [aria-hidden="true"] {
      display: none;
    }
  }
</style>
