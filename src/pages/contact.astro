---
import BaseLayout from "../layouts/BaseLayout.astro";

const EMAIL = "trevor.schilling@timberandtideswoodcraft.com";
const SUBJECT = "Commission Request";
const mailto = `mailto:${EMAIL}?subject=${encodeURIComponent(SUBJECT)}`;
---

<BaseLayout
  title="Commission a Custom Piece — Timber and Tides Woodcraft (Milliken, CO)"
  description="Reach out to commission custom furniture or cabinets from Timber and Tides Woodcraft. Based in Milliken, Colorado — serving Fort Collins, Loveland, Greeley, Boulder, and the Denver metro."
>

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden py-16">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: url('/images/backgrounds/background-4_large.jpg'); background-size: cover; background-position: center;"
    ></div>
    <div class="absolute inset-0 bg-zinc-900/65 pointer-events-none"></div>

    <div class="relative mx-auto max-w-6xl px-4">
      <span class="inline-block rounded-full bg-black/50 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-primary ring-1 ring-inset ring-primary">Get in Touch</span>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight">Contact</h1>
      <p class="mt-4 text-lg text-fg leading-relaxed">
        Want a custom piece? Send me a note and I’ll get back to you with questions, timing, and an estimate.
      </p>
    </div>
  </section>

  <!-- ── Email ──────────────────────────────────────────────────────────────── -->
  <section class="py-12">
    <div class="mx-auto max-w-6xl px-4">
      <p class="text-xs font-semibold uppercase tracking-widest text-muted">Email</p>
      <a class="mt-2 block text-2xl font-bold text-fg hover:text-white transition" href={mailto}>
        {EMAIL}
      </a>
      <p class="mt-2 text-sm text-muted">I typically respond within a day or two.</p>
      <p class="mt-4 text-sm text-muted">
        Based in <span class="text-fg">Milliken, Colorado</span> — serving Fort Collins,
        Loveland, Greeley, Windsor, Longmont, Boulder, and the Denver metro. Local
        delivery is included; shipping is available anywhere in the lower 48.
      </p>
    </div>
  </section>

  <!-- ── What to include ────────────────────────────────────────────────────── -->
  <section class="bg-surface py-12">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="text-xl font-bold tracking-tight border-l-[3px] border-primary pl-3">
        What to include
      </h2>
      <p class="mt-3 text-muted text-sm">
        The more detail you share upfront, the faster I can put together an estimate.
      </p>
      <ul class="mt-5 space-y-3">
        {[
          ["What you want built", "A brief description, a sketch, inspiration photos, and/or links will assist in the design process. Pinterest, Google Images, or AI-generated images are good starting points. Bear in mind that AI-generated images can produce shapes and layouts that are not always possible to achieve."],
          ["Approximate dimensions", "Rough width, depth, and height if you have them in mind, or the size of the space you want the project to fit in."],
          ["Wood species + desired finish", "Cherry, walnut, maple, white oak - or just tell me the look you're after."],
          ["Deadline", "Let me know if there's a date you're working toward."],
          ["Budget range", "Helps me propose options that fit what you have in mind."],
        ].map(([label, detail]) => (
          <li class="flex gap-4">
            <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/20">
              <svg class="h-3 w-3 text-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </span>
            <div>
              <p class="text-sm font-semibold text-fg">{label}</p>
              <p class="mt-0.5 text-sm text-muted">{detail}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────────────────────── -->
  <section class="py-12">
    <div class="mx-auto max-w-6xl px-4 text-center">
      <h2 class="text-xl font-bold tracking-tight">Ready to start?</h2>
      <p class="mt-2 text-muted">Browse the portfolio first, or reach out directly.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a
          href={mailto}
          class="inline-flex items-center rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-bg transition hover:brightness-110"
        >
          Send an Email
        </a>
        <a
          href="/projects/"
          class="inline-flex items-center rounded-xl border border-border bg-surface-2 px-5 py-2.5 text-sm font-semibold text-fg transition hover:bg-surface"
        >
          Browse Projects
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
