---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagPill from "../../components/TagPill.astro";
import { getCollection } from "astro:content";

const plans = (await getCollection("plans")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout
  title="Free Woodworking Plans & Cut Lists — Timber and Tides Woodcraft"
  description="Free downloadable woodworking plans with cut lists and dimensioned drawings, from builds completed in the shop."
>

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden py-16">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: url('/images/backgrounds/background-3_large.jpg'); background-size: cover; background-position: center;"
    ></div>
    <div class="absolute inset-0 bg-zinc-900/65 pointer-events-none"></div>

    <div class="relative mx-auto max-w-6xl px-4">
      <span class="inline-block rounded-full bg-black/50 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-secondary ring-1 ring-inset ring-secondary">Free Downloads</span>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight">Plans</h1>
      <p class="mt-4 text-lg text-fg leading-relaxed max-w-2xl">
        Free downloadable plans and cut lists for builds from the shop. More plans coming soon.
      </p>
    </div>
  </section>

  <!-- ── Plan Cards ─────────────────────────────────────────────────────────── -->
  <section class="py-12">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {plans.map((plan) => (
          <a
            href={`/plans/${plan.slug}/`}
            class="group flex flex-col rounded-2xl border border-border bg-surface transition hover:border-zinc-600 hover:bg-surface-2"
          >
            <div class="flex flex-1 flex-col p-5">
              <div class="flex items-start justify-between gap-3">
                <h2 class="text-base font-semibold text-fg group-hover:text-white transition">
                  {plan.data.title}
                </h2>
                {plan.data.difficulty && (
                  <span class="shrink-0 rounded-full border border-border px-2 py-0.5 text-xs text-muted">
                    {plan.data.difficulty}
                  </span>
                )}
              </div>

              {plan.data.excerpt && (
                <p class="mt-2 text-sm text-muted line-clamp-3">{plan.data.excerpt}</p>
              )}

              <div class="mt-auto pt-4">
                {plan.data.dimensions && (
                  <p class="text-xs text-muted">Size: {plan.data.dimensions}</p>
                )}

                {plan.data.tags.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-1">
                    {plan.data.tags.map((t) => <TagPill tag={t} />)}
                  </div>
                )}
              </div>
            </div>

            <div class="border-t border-border px-5 py-3">
              <span class="text-xs font-semibold text-secondary group-hover:text-fg transition">
                View plan & download →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Coming Soon + Suggest ─────────────────────────────────────────────── -->
  <section class="bg-surface py-12">
    <div class="mx-auto max-w-6xl px-4 text-center">
      <h2 class="text-xl font-bold tracking-tight">More plans coming soon</h2>
      <p class="mt-2 text-muted">
        New plans are added as builds are completed. Have a project you'd love to see a plan for?
      </p>
      <a
        href="/contact/"
        class="mt-6 inline-flex items-center rounded-xl bg-secondary px-5 py-2.5 text-sm font-semibold text-bg transition hover:brightness-110"
      >
        Suggest a plan idea
      </a>
    </div>
  </section>

</BaseLayout>
