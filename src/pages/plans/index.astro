---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagPill from "../../components/TagPill.astro";
import { getCollection } from "astro:content";

const plans = (await getCollection("plans")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Plans — Timber & Tides Woodcraft" description="Free downloadable woodworking plans and cut lists.">
  <section class="py-8">
    <div class="mx-auto max-w-6xl px-4">
      <h1 class="text-3xl font-bold tracking-tight">Plans</h1>
      <p class="mt-2 text-muted max-w-2xl">
        Free downloadable plans and cut lists for builds from the shop. More coming soon.
      </p>

      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {plans.map((plan) => (
          <a
            href={`/plans/${plan.slug}/`}
            class="group flex flex-col rounded-2xl border border-border bg-surface transition hover:border-zinc-600 hover:bg-surface-2"
          >
            <div class="flex flex-1 flex-col p-5">
              <div class="flex items-start justify-between gap-3">
                <h2 class="text-base font-semibold text-fg group-hover:text-white transition">
                  {plan.data.title}
                </h2>
                {plan.data.difficulty && (
                  <span class="shrink-0 rounded-full border border-border px-2 py-0.5 text-xs text-muted">
                    {plan.data.difficulty}
                  </span>
                )}
              </div>

              {plan.data.excerpt && (
                <p class="mt-2 text-sm text-muted line-clamp-3">{plan.data.excerpt}</p>
              )}

              <div class="mt-auto pt-4">
                {plan.data.dimensions && (
                  <p class="text-xs text-muted">Size: {plan.data.dimensions}</p>
                )}

                {plan.data.tags.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-1">
                    {plan.data.tags.map((t) => <TagPill tag={t} />)}
                  </div>
                )}
              </div>
            </div>

            <div class="border-t border-border px-5 py-3">
              <span class="text-xs font-semibold text-primary group-hover:text-fg transition">
                View plan & download →
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-10 rounded-2xl border border-border bg-surface px-6 py-6">
        <p class="text-sm text-muted">
          Don't see what you're looking for?
          <a href="/contact/" class="ml-1 font-semibold text-fg hover:text-white transition">
            Suggest a plan idea →
          </a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
