---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagPill from "../../components/TagPill.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const plans = await getCollection("plans");
  return plans.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const plans = await getCollection("plans");
const plan = plans.find((p) => p.slug === slug);
if (!plan) throw new Error(`Plan not found: ${slug}`);

const { Content } = await plan.render();
const d = plan.data;
---

<BaseLayout title={`${d.title} — Plans`} description={d.excerpt ?? "Woodworking plan details and download."}>
  <article class="py-8">
    <div class="mx-auto max-w-3xl px-4">
      <a href="/plans/" class="text-sm text-muted hover:text-fg transition">← Back to plans</a>

      <!-- Title + top download button -->
      <div class="mt-4 flex flex-wrap items-start justify-between gap-4">
        <div>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">{d.title}</h1>

          <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted">
            <span>{d.date.toLocaleDateString()}</span>
            {d.difficulty && (
              <span class="font-medium text-secondary">• {d.difficulty}</span>
            )}
            {d.dimensions && <span>• {d.dimensions}</span>}
          </div>

          {d.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
              {d.tags.map((t) => <TagPill tag={t} />)}
            </div>
          )}
        </div>

        <a
          href={d.file}
          download
          class="group inline-flex shrink-0 items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-bg
                 transition will-change-transform
                 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-black/30 hover:brightness-110
                 active:translate-y-0
                 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
          </svg>
          Download Plan
        </a>
      </div>

      <!-- Materials card -->
      {d.materials.length > 0 && (
        <div class="mt-8 rounded-2xl border border-secondary/30 bg-surface p-5">
          <h2 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-secondary">
            <span class="h-px flex-1 bg-secondary/30"></span>
            Materials
            <span class="h-px flex-1 bg-secondary/30"></span>
          </h2>
          <ul class="mt-4 space-y-2">
            {d.materials.map((m) => (
              <li class="flex items-start gap-3 text-sm text-fg">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-secondary"></span>
                {m}
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Plan content with styled section headers -->
      <div class="plan-content prose prose-invert mt-8 max-w-none prose-a:text-primary">
        <Content />
      </div>

      <!-- Bottom CTA -->
      <div class="mt-10 flex flex-wrap items-center justify-between gap-4 rounded-2xl border border-border bg-surface px-6 py-5">
        <div>
          <p class="text-sm font-semibold text-fg">Ready to build?</p>
          <p class="mt-0.5 text-sm text-muted">Download the full plans and cut list as a PDF.</p>
        </div>
        <a
          href={d.file}
          download
          class="group inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-bg
                 transition will-change-transform
                 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-black/30 hover:brightness-110
                 active:translate-y-0
                 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
          </svg>
          Download Plan
        </a>
      </div>

      <!-- Related project link -->
      {d.projectSlug && (
        <div class="mt-4">
          <a href={`/projects/${d.projectSlug}/`} class="text-sm text-primary hover:text-fg transition">
            See the finished build →
          </a>
        </div>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  /* Style h2 section headers as distinct color-accented blocks */
  .plan-content :global(h2) {
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    padding-left: 0.875rem;
    border-left: 3px solid #8e9d60; /* --color-secondary / sage */
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #f3f4f6; /* --color-fg */
    text-transform: none;
  }

  /* Thin rule above each h2 for visual separation between sections */
  .plan-content :global(h2:not(:first-child)) {
    margin-top: 2.25rem;
  }

  .plan-content :global(h2:not(:first-child)::before) {
    content: "";
    display: block;
    margin-bottom: 0.75rem;
    border-top: 1px solid #23262b; /* --color-border */
  }

  /* Body text within plan content */
  .plan-content :global(p) {
    color: #b6bcc2; /* --color-muted */
    line-height: 1.7;
  }

  /* Lists */
  .plan-content :global(ul) {
    padding-left: 1.25rem;
  }

  .plan-content :global(li) {
    color: #b6bcc2;
    margin-bottom: 0.4rem;
    padding-left: 0.25rem;
  }

  .plan-content :global(li::marker) {
    color: #8e9d60; /* --color-secondary */
  }
</style>
